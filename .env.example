# ==========================================
# ScholarAgent environment configuration
# Copy this file to .env and edit local values.
# ==========================================

# ------------------------------------------
# Core paths
# ------------------------------------------
# Runtime workspace for database, papers, models, and logs.
WORKSPACE_DIR=./workspace
PAPERS_DIR=./workspace/papers
BGE_M3_MODEL_PATH=./workspace/models/bge-m3
BGE_RERANKER_MODEL_PATH=./workspace/models/bge-reranker-v2-m3
PAPER_PARSER_DEVICE=auto

# Parent directory for generated code and generated documents.
SCHOLAR_AGENT_WORK_ROOT=D:/scholar agent
CODE_BUILDER_WORKSPACE_DIR=D:/scholar agent/scholar code
CODE_BUILDER_PYTHON_EXECUTABLE=D:/
WRITING_WORKSPACE_DIR=D:/scholar agent/scholar document

# ------------------------------------------
# Main LLM provider
# ------------------------------------------
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-chat

# ------------------------------------------
# Per-agent LLM overrides
# Leave blank to inherit LLM_API_KEY / LLM_BASE_URL / LLM_MODEL_NAME.
# ------------------------------------------
AGENT_SUPERVISOR_API_KEY=
AGENT_SUPERVISOR_BASE_URL=
AGENT_SUPERVISOR_MODEL=

AGENT_SUMMARIZER_API_KEY=
AGENT_SUMMARIZER_BASE_URL=
AGENT_SUMMARIZER_MODEL=

AGENT_METHODOLOGY_API_KEY=
AGENT_METHODOLOGY_BASE_URL=
AGENT_METHODOLOGY_MODEL=

AGENT_CODE_BUILDER_API_KEY=
AGENT_CODE_BUILDER_BASE_URL=
AGENT_CODE_BUILDER_MODEL=

AGENT_WRITING_EDITOR_API_KEY=
AGENT_WRITING_EDITOR_BASE_URL=
AGENT_WRITING_EDITOR_MODEL=

AGENT_LITERATURE_API_KEY=
AGENT_LITERATURE_BASE_URL=
AGENT_LITERATURE_MODEL=

# ------------------------------------------
# Agent model parameters
# ------------------------------------------
AGENT_LLM_TIMEOUT=60

AGENT_SUPERVISOR_TEMPERATURE=0.2
AGENT_SUPERVISOR_MAX_TOKENS=2048
AGENT_SUPERVISOR_SYNTHESIS_TEMPERATURE=0.3
AGENT_SUPERVISOR_SYNTHESIS_MAX_TOKENS=3072

AGENT_SUMMARIZER_TEMPERATURE=0.3
AGENT_SUMMARIZER_MAX_TOKENS=4096

AGENT_METHODOLOGY_TEMPERATURE=0.2
AGENT_METHODOLOGY_MAX_TOKENS=4096

AGENT_CODE_BUILDER_TEMPERATURE=0.1
AGENT_CODE_BUILDER_MAX_TOKENS=8192
AGENT_CODE_BUILDER_AUTONOMOUS=true

AGENT_WRITING_EDITOR_TEMPERATURE=0.2
AGENT_WRITING_EDITOR_MAX_TOKENS=8192

AGENT_LITERATURE_TEMPERATURE=0.3
AGENT_LITERATURE_MAX_TOKENS=3072

# ------------------------------------------
# HyDE retrieval expansion
# ------------------------------------------
ENABLE_HYDE=true
HYDE_MAX_TOKENS=256
HYDE_TEMPERATURE=0.1

# ------------------------------------------
# Context and truncation limits
# ------------------------------------------
SUPERVISOR_EXPERT_OUTPUT_TRUNC=600
SUPERVISOR_MESSAGE_TRUNC=800
SUPERVISOR_TOOL_RESULT_TRUNC=600
SUPERVISOR_SYNTHESIS_CONTENT_TRUNC=4000

EXPERT_MESSAGE_OUTPUT_TRUNC=3000
EXPERT_CONTEXT_MAX_CHARS_PER_PAPER=8000
EXPERT_METHODOLOGY_MAX_CHARS_PER_PAPER=10000
EXPERT_LITERATURE_MAX_LOCAL_PREVIEW=15
EXPERT_LITERATURE_ARXIV_MAX_RESULTS=5

# ------------------------------------------
# Default fallback text
# ------------------------------------------
DEFAULT_PAPER_TITLE=Unknown
DEFAULT_LITERATURE_QUERY=research paper
DEFAULT_SUMMARIZER_QUERY=paper summary
DEFAULT_METHODOLOGY_QUERY_SUFFIX=method algorithm architecture

# ------------------------------------------
# Web server
# ------------------------------------------
WEB_HOST=127.0.0.1
WEB_PORT=8000
WEB_RELOAD=false
WEB_RELOAD_DIRS=.

# ------------------------------------------
# External MCP tools
# ------------------------------------------
ENABLE_EXTERNAL_MCP=true
MCP_SERVERS_CONFIG=./mcp_servers.yaml
MCP_CONNECT_TIMEOUT=30

# MATLAB MCP server command used by mcp_servers.json / mcp_servers.yaml.
MATLAB_MCP_PYTHON_EXECUTABLE=D:/Anaconda/envs/scholaragent311/python.exe
MATLAB_MCP_SERVER_PATH=path/to/matlab_mcp_server.py

# ------------------------------------------
# Skill system
# ------------------------------------------
ENABLE_SKILLS=true
SKILLS_DIR=./skills

# ------------------------------------------
# Agent memory
# ------------------------------------------
ENABLE_AGENT_MEMORY=true
AGENT_MEMORY_DB=./workspace/db/agent_memory.db
AGENT_MEMORY_SUMMARY_MAX_CHARS=2400
AGENT_MEMORY_PROMPT_MAX_CHARS=1400
AGENT_MEMORY_MAX_TOPICS=8
AGENT_MEMORY_MAX_PAPER_IDS=20
AGENT_MEMORY_MAX_EVENTS=80

# ------------------------------------------
# Logging
# ------------------------------------------
SCHOLAR_AGENT_LOG_DIR=./workspace/logs
SCHOLAR_AGENT_LOG_FILE=./workspace/logs/scholar_agent.log
SCHOLAR_AGENT_LOG_LEVEL=INFO
SCHOLAR_AGENT_LOG_TO_CONSOLE=true
SCHOLAR_AGENT_LOG_MAX_BYTES=10485760
SCHOLAR_AGENT_LOG_BACKUP_COUNT=5
