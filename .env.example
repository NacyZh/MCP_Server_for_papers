# ScholarAgent RAG MCP server configuration

# Runtime directories
PAPERS_DIR=./workspace/papers
DB_DIR=./rag/db
MODELS_DIR=./rag/models

# BGE retrieval models. If missing and BGE_AUTO_DOWNLOAD=true, models are
# downloaded from Hugging Face into these paths.
BGE_M3_MODEL_PATH=./rag/models/bge-m3
BGE_RERANKER_MODEL_PATH=./rag/models/bge-reranker-v2-m3
BGE_AUTO_DOWNLOAD=true
BGE_OFFLINE_MODE=false
BGE_M3_MODEL_REPO=BAAI/bge-m3
BGE_RERANKER_MODEL_REPO=BAAI/bge-reranker-v2-m3
BGE_M3_MODEL_REVISION=main
BGE_RERANKER_MODEL_REVISION=main
BGE_MODEL_LOCK_TIMEOUT_SEC=600
BGE_MODEL_LOCK_STALE_SEC=3600

# PDF parser device: auto, cpu, or cuda. Use cuda only when the active Python
# environment has CUDA-enabled PyTorch.
PAPER_PARSER_DEVICE=auto

# Optional HyDE query expansion. HYDE_BACKEND=api uses an OpenAI-compatible
# chat endpoint; HYDE_BACKEND=vllm uses a local vLLM model.
ENABLE_HYDE=true
HYDE_BACKEND=api
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_NAME=
HYDE_API_TIMEOUT=60
HYDE_MAX_TOKENS=256
HYDE_TEMPERATURE=0.1

# Local HyDE inference with vLLM
HYDE_VLLM_MODEL_PATH=./rag/finetune/models/hyde-qwen-lora
HYDE_VLLM_DTYPE=auto
HYDE_VLLM_TENSOR_PARALLEL_SIZE=1
HYDE_VLLM_GPU_MEMORY_UTILIZATION=0.85
HYDE_VLLM_MAX_MODEL_LEN=2048

# Cached paper summary generation. RAG_SUMMARY_BACKEND=api calls an
# OpenAI-compatible chat endpoint; RAG_SUMMARY_BACKEND=vllm loads a local model
# in-process on Linux/WSL.
RAG_SUMMARY_MODEL_NAME=Qwen/Qwen3-8B-AWQ
RAG_SUMMARY_BACKEND=api
RAG_SUMMARY_API_BASE_URL=
RAG_SUMMARY_API_KEY=
RAG_SUMMARY_API_MODEL=
RAG_SUMMARY_API_TIMEOUT_SECONDS=180
RAG_SUMMARY_API_MAX_RETRIES=2
RAG_SUMMARY_API_HEALTH_TIMEOUT_SECONDS=2
RAG_SUMMARY_MODEL_PATH=./rag/models/Qwen3-8B-AWQ
RAG_SUMMARY_MODEL_REPO=Qwen/Qwen3-8B-AWQ
RAG_SUMMARY_MODEL_REVISION=main
RAG_SUMMARY_AUTO_DOWNLOAD=true
RAG_SUMMARY_OFFLINE_MODE=false
RAG_SUMMARY_DEVICE=cuda
RAG_SUMMARY_DTYPE=auto
RAG_SUMMARY_TENSOR_PARALLEL_SIZE=1
RAG_SUMMARY_GPU_MEMORY_UTILIZATION=0.75
RAG_SUMMARY_CPU_OFFLOAD_GB=0
RAG_SUMMARY_MAX_INPUT_TOKENS=4096
RAG_SUMMARY_MAX_OUTPUT_TOKENS=2048
RAG_SUMMARY_TEMPERATURE=0.2
RAG_SUMMARY_TOP_P=0.8
RAG_SUMMARY_CONCURRENCY=1
RAG_SUMMARY_TIMEOUT_SECONDS=300
RAG_SUMMARY_PROMPT_VERSION=qwen3-summary-v1
RAG_SUMMARY_ENFORCE_EAGER=true

# Tool safety and response limits
TOOL_MAX_QUERY_CHARS=800
TOOL_MAX_SECTION_CHARS=120
TOOL_MAX_RETURN_CHARS=20000
TOOL_MAX_PAPER_IDS=20
TOOL_JOB_STATUS_WAIT_INITIAL_SECONDS=1
TOOL_JOB_STATUS_WAIT_STEP_SECONDS=1
TOOL_JOB_STATUS_WAIT_MAX_SECONDS=10

# Retrieval quality evaluation
RETRIEVAL_EVAL_DATASET_PATH=./rag/evaluation/data/retrieval_eval.jsonl
RETRIEVAL_EVAL_RESULTS_DIR=./rag/evaluation/results
RETRIEVAL_EVAL_MAX_CASES=200

# Logging
RAG_LOG_DIR=./rag/logs
RAG_LOG_FILE=./rag/logs/rag.log
RAG_LOG_LEVEL=INFO
RAG_LOG_TO_CONSOLE=false
RAG_LOG_MAX_BYTES=10485760
RAG_LOG_BACKUP_COUNT=5
